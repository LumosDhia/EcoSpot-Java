<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #f8fbf9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.event.EventFormController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <top>
        <VBox>
            <!-- ===== TOP DARK BAR ===== -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="top-bar">
                <padding><Insets bottom="8.0" left="20.0" right="20.0" top="8.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHome" style="-fx-cursor: hand;" styleClass="top-bar-brand" text="🌿 EcoSpot | Event Editor" />
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER_RIGHT" spacing="0">
                        <Button onAction="#handleMinimize" styleClass="win-btn" text="—" />
                        <Button onAction="#handleMaximize" styleClass="win-btn" text="❐" />
                        <Button onAction="#handleClose" styleClass="win-btn, win-close" text="✕" />
                    </HBox>
                </children>
            </HBox>

            <!-- ===== WHITE SECONDARY NAV ===== -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="main-nav">
                <padding><Insets bottom="12.0" left="20.0" right="20.0" top="12.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHome" style="-fx-cursor: hand;" styleClass="brand-name" text="EcoSpot" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#goToHome" styleClass="nav-link-btn" text="Home" />
                    <Button onAction="#goToEvents" styleClass="nav-link-btn-active" text="Events" />
                    <Button onAction="#goToTickets" styleClass="nav-link-btn" text="🎟 Tickets" />
                    <Button onAction="#goToAchievements" styleClass="nav-link-btn" text="Achievements" />
                    <Button onAction="#goToBlog" styleClass="nav-btn-blog" text="Blog" />
                </children>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <VBox alignment="CENTER" spacing="25.0">
                    <padding><Insets bottom="40.0" left="60.0" right="60.0" top="40.0" /></padding>
                    <children>
                        <VBox maxWidth="600.0" spacing="20.0" styleClass="section-card">
                            <padding><Insets top="30.0" bottom="30.0" left="30.0" right="30.0" /></padding>
                            <children>
                                <Label fx:id="formTitle" styleClass="section-title" text="Add New Event" />

                                <VBox spacing="10.0">
                                    <children>
                                        <Label styleClass="form-label" text="Event Name (*)" />
                                        <TextField fx:id="nameField" promptText="Enter event name (min 5 chars)..." styleClass="search-field" />
                                    </children>
                                </VBox>

                                <VBox spacing="10.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label styleClass="form-label" text="Location (*)" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button onAction="#handleGeocode" style="-fx-font-size: 10; -fx-padding: 2 8; -fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="📍 Find on Map" />
                                            </children>
                                        </HBox>
                                        <TextField fx:id="locationField" promptText="City, Country..." styleClass="search-field" />
                                    </children>
                                </VBox>

                                <HBox spacing="20.0">
                                    <children>
                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="form-label" text="Capacity (*)" />
                                                <TextField fx:id="capacityField" promptText="Max participants (number)" styleClass="search-field" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="form-label" text="Event Image (*)" />
                                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                    <children>
                                                        <Button onAction="#importImage" styleClass="nav-link-btn" text="📁 Import" />
                                                        <Label fx:id="imageNameLabel" styleClass="card-text" text="No image selected" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="20.0">
                                    <children>
                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="form-label" text="Start Date (*)" />
                                                <DatePicker fx:id="startDatePicker" editable="false" maxWidth="Infinity" styleClass="search-field" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="form-label" text="End Date (*)" />
                                                <DatePicker fx:id="endDatePicker" editable="false" maxWidth="Infinity" styleClass="search-field" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="10.0">
                                    <children>
                                        <Label styleClass="form-label" text="Description (*)" />
                                        <TextArea fx:id="descriptionArea" prefHeight="120.0" promptText="Describe the event goals and activities (min 20 chars)..." styleClass="search-field" wrapText="true" />
                                    </children>
                                </VBox>

                                <VBox spacing="10.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label styleClass="form-label" text="Sponsors" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button onAction="#openSponsorPicker" styleClass="btn-secondary" text="+ Select Sponsors" />
                                            </children>
                                        </HBox>
                                        <FlowPane fx:id="selectedSponsorsFlow" hgap="10.0" vgap="10.0" />
                                    </children>
                                </VBox>

                                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                    <children>
                                        <Button onAction="#handleAiPredict" styleClass="nav-btn-blog" text="🔮 AI Predict Success" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button onAction="#cancel" styleClass="btn-outline" text="Cancel" />
                                        <Button fx:id="saveBtn" onAction="#save" styleClass="btn-hero-primary" text="Save Event" />
                                    </children>
                                </HBox>

                                <VBox fx:id="aiResultBox" managed="false" spacing="10.0" style="-fx-background-color: #f0f7f4; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #2d6a4f; -fx-border-width: 0.5;" visible="false">
                                    <children>
                                        <HBox spacing="10.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #2d6a4f;" text="AI Prediction:" />
                                                <Label fx:id="aiSuccessLabel" style="-fx-font-weight: bold; -fx-text-fill: #fca311;" text="HIGH" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="aiAnalysisLabel" style="-fx-text-fill: #444; -fx-font-size: 13;" text="Analysis goes here..." wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
