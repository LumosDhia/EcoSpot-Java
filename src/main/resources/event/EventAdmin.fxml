<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #f8fbf9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.event.EventAdminController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <top>
        <VBox>
            <!-- ===== TOP BRANDED BAR ===== -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="top-bar">
                <padding><Insets bottom="8.0" left="20.0" right="20.0" top="8.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHome" style="-fx-cursor: hand;" styleClass="top-bar-brand" text="🌿 EcoSpot | Admin Dashboard" />
                    <Region HBox.hgrow="ALWAYS" />
                </children>
            </HBox>

            <!-- ===== WHITE SECONDARY NAV ===== -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="main-nav">
                <padding><Insets bottom="12.0" left="20.0" right="20.0" top="12.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHome" style="-fx-cursor: hand;" styleClass="brand-name" text="EcoSpot" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#goToHome" styleClass="nav-link-btn" text="Home" />
                    <Button onAction="#goToEvents" styleClass="nav-link-btn" text="Events Discovery" />
                    <Button onAction="#goToBlog" styleClass="nav-btn-blog" text="Blog" />
                </children>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="20.0">
            <padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label styleClass="section-title" text="Event Management" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#openAddEvent" styleClass="btn-hero-primary" text="+ Create New Event" />
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <content>
                        <FlowPane fx:id="eventContainer" hgap="30.0" vgap="30.0">
                            <padding><Insets bottom="20.0" left="10.0" right="10.0" top="10.0" /></padding>
                        </FlowPane>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </center>
</BorderPane>
