<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="280.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.event.SponsorCardController">
    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
    <children>
        <StackPane style="-fx-background-color: #f0f2f0; -fx-background-radius: 10;">
            <children>
                <ImageView fx:id="sponsorImage" fitHeight="150.0" fitWidth="250.0" pickOnBounds="true" preserveRatio="true" />
            </children>
        </StackPane>
        
        <VBox spacing="5.0">
            <children>
                <Label fx:id="nameLabel" style="-fx-font-weight: bold; -fx-font-size: 18;" text="Sponsor Name" />
                <Label fx:id="sectorLabel" style="-fx-text-fill: #2d6a4f; -fx-font-weight: bold;" text="Sector" />
                <Label fx:id="locationLabel" style="-fx-text-fill: gray;" text="Location" />
                <Separator />
                <Label fx:id="descriptionLabel" prefHeight="60.0" style="-fx-text-fill: #555;" wrapText="true" text="Description..." />
            </children>
        </VBox>
        
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button onAction="#editSponsor" styleClass="btn-secondary" text="Edit" />
                <Button onAction="#deleteSponsor" style="-fx-background-color: #ffeded; -fx-text-fill: #e63946; -fx-border-color: #e63946; -fx-border-radius: 5;" text="Delete" />
            </children>
        </HBox>
    </children>
</VBox>
