<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720.0" prefWidth="1280.0" spacing="15.0" style="-fx-background-color: #f8faf9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.blog.CategoriesManagementController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <padding>
        <Insets top="20.0" right="24.0" bottom="20.0" left="24.0" />
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Button onAction="#goBack" styleClass="btn-outline" text="← Back" />
                <Button onAction="#goToDashboard" styleClass="btn-outline" text="Dashboard" />
                <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2d6a4f;" text="Categories Management" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 14; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
            <children>
                <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #333;" text="Categories" />
                <Label style="-fx-text-fill: #666;" text="Edit applies globally. Delete removes the category from all related articles." wrapText="true" />
                <TableView fx:id="categoriesTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colCategoryName" text="Category" />
                        <TableColumn fx:id="colCategoryArticles" text="Articles" />
                        <TableColumn fx:id="colCategoryActions" text="Actions" />
                    </columns>
                </TableView>
                <Label style="-fx-font-weight: bold; -fx-text-fill: #333;" text="Articles in selected category" />
                <ListView fx:id="categoryArticlesList" prefHeight="180.0" />
            </children>
        </VBox>
    </children>
</VBox>
