<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="cardContainer" prefWidth="280.0" spacing="0" styleClass="article-card" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.blog.BlogCardController">
   <children>
      <StackPane prefHeight="180.0">
         <children>
            <ImageView fx:id="articleImage" fitHeight="180.0" fitWidth="280.0" pickOnBounds="true" preserveRatio="false">
               <image>
                  <Image url="https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?w=800" />
               </image>
            </ImageView>
         </children>
      </StackPane>
      <VBox spacing="12" style="-fx-padding: 15;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10">
               <children>
                  <Label fx:id="categoryLabel" styleClass="category-tag" text="Energy" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="dateLabel" styleClass="article-date" text="15 minutes ago">
                     <graphic>
                        <Label style="-fx-text-fill: #64748b;" text="📅" />
                     </graphic>
                  </Label>
               </children>
            </HBox>
            
            <Label fx:id="titleLabel" styleClass="article-title" text="hufhuhu ijoij" wrapText="true" />
            
            <HBox fx:id="statsBar" alignment="CENTER_LEFT" spacing="15.0" styleClass="article-stats-bar">
               <children>
                  <Label fx:id="viewsLabel" styleClass="stat-item" text="👁 3" />
                  <Label fx:id="likesLabel" styleClass="stat-item" text="👍 0" />
                  <Label fx:id="dislikesLabel" styleClass="stat-item" text="👎 0" />
                  <Label fx:id="readTimeLabel" styleClass="stat-item" text="👤 1m" />
                  <Label fx:id="commentsLabel" styleClass="stat-item" text="💬 0" />
               </children>
            </HBox>

            <Label fx:id="authorLabel" styleClass="article-author" text="👤 Admin User">
                <graphic>
                    <Label style="-fx-text-fill: #64748b;" text="🖋" />
                </graphic>
            </Label>

            <TextFlow prefHeight="60.0">
               <children>
                  <Text fx:id="excerptText" styleClass="article-excerpt" text="jij ijoiijiojijioiji ioj ijijo joijoijij ioj ij joijiojijio j jjoijiojijjo jijioiWrite your article..." />
               </children>
            </TextFlow>

            <FlowPane fx:id="tagsFlowPane" hgap="5.0" vgap="5.0" />

            <Button fx:id="readMoreBtn" maxWidth="1.7976931348623157E308" styleClass="read-more-btn" text="Read more" />
         </children>
      </VBox>
   </children>
</VBox>
