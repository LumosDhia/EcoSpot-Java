<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox fx:id="cardContainer" prefWidth="300.0" spacing="0" styleClass="article-card" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.blog.BlogCardController">
   <children>
      <!-- Image with overlay -->
      <StackPane prefHeight="190.0" styleClass="card-image-wrapper">
         <children>
            <ImageView fx:id="articleImage" fitHeight="190.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="false" />
            <!-- Category overlay on image -->
            <HBox alignment="TOP_LEFT" StackPane.alignment="TOP_LEFT" style="-fx-padding: 12;">
               <children>
                  <Label fx:id="categoryLabel" styleClass="category-tag-overlay" text="Energy" />
               </children>
            </HBox>
         </children>
      </StackPane>
      
      <!-- Card body -->
      <VBox spacing="10" styleClass="card-body">
         <children>
            <!-- Date -->
            <Label fx:id="dateLabel" styleClass="card-date-label" text="15 minutes ago" />
            
            <!-- Title -->
            <Label fx:id="titleLabel" styleClass="card-title-label" text="Article Title" wrapText="true" />
            
            <!-- Excerpt -->
            <TextFlow prefHeight="48.0" styleClass="card-excerpt-flow">
               <children>
                  <Text fx:id="excerptText" styleClass="article-excerpt" text="Article excerpt goes here..." />
               </children>
            </TextFlow>

            <!-- Tags -->
            <FlowPane fx:id="tagsFlowPane" hgap="5.0" vgap="5.0" />

            <!-- Divider -->
            <Region styleClass="card-divider" />

            <!-- Stats row -->
            <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="card-stats-row">
               <children>
                  <Label fx:id="viewsLabel" styleClass="stat-badge-chip" text="👁 0" />
                  <Label fx:id="likesLabel" styleClass="stat-badge-chip" text="👍 0" />
                  <Label fx:id="dislikesLabel" styleClass="stat-badge-chip" text="👎 0" />
                  <Label fx:id="commentsLabel" styleClass="stat-badge-chip" text="💬 0" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="readTimeLabel" styleClass="stat-badge-chip-alt" text="📖 1m" />
               </children>
            </HBox>

            <!-- Author + Read More -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label fx:id="authorLabel" styleClass="card-author-label" text="Admin User" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="readMoreBtn" styleClass="card-read-more-btn" text="Read →" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
