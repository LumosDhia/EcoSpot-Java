<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.blog.ArticleStatsController" style="-fx-background-color: #f4f6f8;">
    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f4f6f8;">
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Button fx:id="backBtn" mnemonicParsing="false" onAction="#goBack" text="← Back to All Stats" style="-fx-font-size: 14; -fx-padding: 8 16; -fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
            <VBox>
                <Label fx:id="articleTitleLabel" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a202c;" text="Article Title" />
                <Label fx:id="articleMetaLabel" style="-fx-font-size: 14; -fx-text-fill: #718096;" text="By Author | Published on Date" />
            </VBox>
        </HBox>

        <!-- KPI Cards -->
        <HBox spacing="20">
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                <Label style="-fx-font-size: 12; -fx-text-fill: #718096; -fx-font-weight: bold;" text="TOTAL VIEWS" />
                <Label fx:id="totalViewsLabel" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="0" />
            </VBox>
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                <Label style="-fx-font-size: 12; -fx-text-fill: #718096; -fx-font-weight: bold;" text="LIKES" />
                <Label fx:id="likesLabel" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #38a169;" text="0" />
            </VBox>
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                <Label style="-fx-font-size: 12; -fx-text-fill: #718096; -fx-font-weight: bold;" text="DISLIKES" />
                <Label fx:id="dislikesLabel" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #e53e3e;" text="0" />
            </VBox>
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                <Label style="-fx-font-size: 12; -fx-text-fill: #718096; -fx-font-weight: bold;" text="COMMENTS" />
                <Label fx:id="commentsLabel" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #3182ce;" text="0" />
            </VBox>
        </HBox>

        <!-- Views Timeline -->
        <VBox style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
            <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="Views Timeline" />
            <AreaChart fx:id="viewsTimelineChart" prefHeight="300" animated="false">
                <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                <yAxis><NumberAxis side="LEFT" /></yAxis>
            </AreaChart>
        </VBox>

        <!-- Article Comments -->
        <VBox style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" VBox.vgrow="ALWAYS">
            <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2d3748; -fx-padding: 0 0 15 0;" text="Article Comments" />
            <ListView fx:id="commentsListView" prefHeight="300" style="-fx-background-insets: 0; -fx-padding: 0; -fx-background-color: transparent;" />
        </VBox>
    </VBox>
</ScrollPane>
