<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane style="-fx-background-color: #e9f5ee;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.blog.CommentsManagementController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="top-bar">
                <padding><Insets bottom="8.0" left="20.0" right="20.0" top="8.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHomeMouse" style="-fx-cursor: hand;" styleClass="top-bar-brand" text="🌿 EcoSpot" />
                    <Region HBox.hgrow="ALWAYS" />
                </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="main-nav">
                <padding><Insets bottom="12.0" left="20.0" right="20.0" top="12.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHomeMouse" style="-fx-cursor: hand;" styleClass="brand-name" text="EcoSpot" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="homeBtn" onAction="#goToHome" styleClass="nav-link-btn" text="Home" />
                    <Button onAction="#goToDashboard" styleClass="nav-link-btn" text="Dashboard" />
                    <Button styleClass="nav-link-btn" text="Events" />
                    <Button styleClass="nav-link-btn" text="🎟 Tickets" />
                    <Button styleClass="nav-link-btn" text="Achievements" />
                    <Button onAction="#goToBlog" styleClass="nav-link-btn" text="Blog" />
                </children>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <VBox spacing="25.0">
                    <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
                    <children>
                        <HBox fx:id="adminHeaderBox" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                            <children>
                                <Button onAction="#goBack" styleClass="nav-link-btn" text="← Back" />
                                <Label fx:id="breadcrumbPrefixLabel" style="-fx-text-fill: #888; -fx-font-size: 14;" text="Admin › " />
                                <Label fx:id="breadcrumbTitleLabel" style="-fx-text-fill: #333; -fx-font-size: 14; -fx-font-weight: bold;" text="Comments" />
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox alignment="CENTER" spacing="15.0">
                                    <Label style="-fx-font-size: 20;" text="🔔" textFill="#ff5c5c"/>
                                    <VBox alignment="CENTER_RIGHT" spacing="0">
                                        <children>
                                            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333;" text="Admin" />
                                            <Label style="-fx-font-size: 11; -fx-text-fill: #888;" text="Verified Citizen" />
                                        </children>
                                    </VBox>
                                    <Circle fill="#ffb703" radius="16.0" />
                                </HBox>
                            </children>
                        </HBox>

                        <VBox fx:id="adminSectionBox" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox style="-fx-padding: 15 20; -fx-border-color: transparent transparent #e0e0e0 transparent; -fx-border-width: 0 0 1 0;" spacing="3">
                                    <children>
                                        <Label fx:id="sectionTitleLabel" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #555;" text="Comment list" />
                                        <Label fx:id="sectionSubtitleLabel" style="-fx-font-size: 12; -fx-text-fill: #777;" text="Comments are created under blog articles. You can view and delete them." />
                                    </children>
                                </VBox>

                                <TableView fx:id="commentsTable" prefHeight="550.0" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                    <columns>
                                        <TableColumn fx:id="colId" text="Id" />
                                        <TableColumn fx:id="colAuthor" text="Author" />
                                        <TableColumn fx:id="colArticle" text="Article" />
                                        <TableColumn fx:id="colDate" text="Date" />
                                        <TableColumn fx:id="colFlagged" text="Flagged" />
                                        <TableColumn fx:id="colActions" text="Actions" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox fx:id="ngoSectionBox" managed="false" spacing="18.0" visible="false">
                            <children>
                                <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                                    <children>
                                        <VBox style="-fx-padding: 15 20; -fx-border-color: transparent transparent #e0e0e0 transparent; -fx-border-width: 0 0 1 0;" spacing="3">
                                            <children>
                                                <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #555;" text="Your comments" />
                                                <Label style="-fx-font-size: 12; -fx-text-fill: #777;" text="Comments written by you. You can view and delete." />
                                            </children>
                                        </VBox>
                                        <TableView fx:id="ngoOwnCommentsTable" prefHeight="250.0" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                            <columns>
                                                <TableColumn fx:id="colOwnId" text="Id" />
                                                <TableColumn fx:id="colOwnArticle" text="Article" />
                                                <TableColumn fx:id="colOwnDate" text="Date" />
                                                <TableColumn fx:id="colOwnFlagged" text="Status" />
                                                <TableColumn fx:id="colOwnActions" text="Actions" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>

                                <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                                    <children>
                                        <VBox style="-fx-padding: 15 20; -fx-border-color: transparent transparent #e0e0e0 transparent; -fx-border-width: 0 0 1 0;" spacing="3">
                                            <children>
                                                <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #555;" text="Comments on your articles" />
                                                <Label style="-fx-font-size: 12; -fx-text-fill: #777;" text="Flag comments if there is an issue. Flagged comments are hidden until admin accepts them." />
                                            </children>
                                        </VBox>
                                        <TableView fx:id="ngoArticleCommentsTable" prefHeight="280.0" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                                            <columns>
                                                <TableColumn fx:id="colArticleCommentId" text="Id" />
                                                <TableColumn fx:id="colArticleCommentAuthor" text="Author" />
                                                <TableColumn fx:id="colArticleCommentArticle" text="Article" />
                                                <TableColumn fx:id="colArticleCommentDate" text="Date" />
                                                <TableColumn fx:id="colArticleCommentFlagged" text="Status" />
                                                <TableColumn fx:id="colArticleCommentActions" text="Actions" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
