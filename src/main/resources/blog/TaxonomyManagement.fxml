<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720.0" prefWidth="1280.0" spacing="15.0" style="-fx-background-color: #f8faf9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.blog.TaxonomyManagementController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <padding>
        <Insets top="20.0" right="24.0" bottom="20.0" left="24.0" />
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Button onAction="#goBack" styleClass="btn-outline" text="← Back" />
                <Label styleClass="page-title" text="Tags Management" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <HBox spacing="16.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox fx:id="categoriesSection" spacing="10.0" styleClass="section-card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="section-heading" text="Categories" />
                        <Label styleClass="section-hint" text="Select a category to see all its articles. Edit applies everywhere. Delete removes it from all articles." wrapText="true" />
                        <TableView fx:id="categoriesTable" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colCategoryName" text="Category" />
                                <TableColumn fx:id="colCategoryArticles" text="Articles" />
                                <TableColumn fx:id="colCategoryActions" text="Actions" />
                            </columns>
                        </TableView>
                        <Label styleClass="section-heading" text="Articles in selected category" />
                        <ListView fx:id="categoryArticlesList" prefHeight="180.0" />
                    </children>
                </VBox>

                <VBox fx:id="tagsSection" spacing="10.0" styleClass="section-card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="section-heading" text="Tags" />
                        <Label styleClass="section-hint" text="Select a tag to see all tagged articles. Edit applies everywhere. Delete removes it from all tagged articles." wrapText="true" />
                        <TableView fx:id="tagsTable" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colTagName" text="Tag" />
                                <TableColumn fx:id="colTagArticles" text="Articles" />
                                <TableColumn fx:id="colTagActions" text="Actions" />
                            </columns>
                        </TableView>
                        <Label styleClass="section-heading" text="Articles with selected tag" />
                        <ListView fx:id="tagArticlesList" prefHeight="180.0" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
