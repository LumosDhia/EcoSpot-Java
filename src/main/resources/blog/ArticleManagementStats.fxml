<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.blog.ArticleManagementStatsController">
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button mnemonicParsing="false" onAction="#goBack" text="← Back to Statistics" style="-fx-font-size: 14; -fx-padding: 8 16; -fx-background-color: #ffffff; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand;" />
        <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a202c;" text="Article Performance Directory" />
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="searchField" prefWidth="300" placeholder="Search by title or author..." style="-fx-font-size: 14; -fx-padding: 10; -fx-background-radius: 8; -fx-border-color: #cbd5e0; -fx-border-radius: 8;" />
    </HBox>

    <!-- Content Card -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
        <TableView fx:id="articlesTable" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-selection-bar: #ebf8ff; -fx-selection-bar-non-focused: #ebf8ff;">
            <columns>
                <TableColumn fx:id="titleColumn" text="Article Title" prefWidth="350" />
                <TableColumn fx:id="authorColumn" text="Author" prefWidth="150" />
                <TableColumn fx:id="viewsColumn" text="Views" prefWidth="100" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="likesColumn" text="Likes" prefWidth="100" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="dislikesColumn" text="Dislikes" prefWidth="100" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="commentsColumn" text="Comments" prefWidth="100" style="-fx-alignment: CENTER;" />
            </columns>
            <placeholder>
                <Label text="No articles found." style="-fx-font-size: 16; -fx-text-fill: #718096;" />
            </placeholder>
        </TableView>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <Label text="Tip: Double-click an article to see detailed day-by-day analytics." style="-fx-font-size: 13; -fx-text-fill: #a0aec0; -fx-font-style: italic;" />
        </HBox>
    </VBox>
</VBox>
