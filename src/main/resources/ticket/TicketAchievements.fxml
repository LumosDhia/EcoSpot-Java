<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1000.0" styleClass="admin-content-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.ticket.TicketAchievementsController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>
    
    <children>
        <!-- TOP BAR -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="admin-top-bar">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <Button onAction="#handleBackHome" style="-fx-background-color: transparent; -fx-text-fill: #2d6a4f; -fx-cursor: hand;" text="⬅ Back" />
                <Label styleClass="breadcrumb-text" text="Community › Eco Achievements" />
                <Region HBox.hgrow="ALWAYS" />
                <Label style="-fx-text-fill: #2d6a4f; -fx-font-weight: bold;" text="🏆 Hall of Fame" />
            </children>
        </HBox>

        <VBox alignment="TOP_CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
            </padding>
            <children>
                <VBox alignment="CENTER" spacing="5.0">
                    <Label text="Heroes of EcoSpot">
                        <font><Font name="System Bold" size="28.0" /></font>
                    </Label>
                    <Label text="Celebrating every action taken towards a cleaner planet." style="-fx-text-fill: #666;" />
                </VBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="achievementsFlow" hgap="20.0" vgap="20.0">
                            <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                        </FlowPane>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</VBox>
