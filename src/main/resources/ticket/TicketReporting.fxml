<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1000.0" styleClass="admin-content-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.ticket.TicketReportingController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>
    
    <children>
        <!-- TOP BAR -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="admin-top-bar">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <Button onAction="#handleBackHome" style="-fx-background-color: transparent; -fx-text-fill: #2d6a4f; -fx-cursor: hand;" text="⬅ Back" />
                <Label styleClass="breadcrumb-text" text="Community › Report Issue" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="10.0">
                    <Label styleClass="admin-profile-name" text="Regular User" />
                    <Label style="-fx-background-color: #fca311; -fx-text-fill: white; -fx-padding: 3 8; -fx-background-radius: 10; -fx-font-size: 11px;" text="Verified Citizen" />
                </HBox>
            </children>
        </HBox>

        <HBox spacing="30.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <!-- Submission Form -->
                <VBox prefWidth="400.0" spacing="20.0" styleClass="stat-card">
                    <children>
                        <Label text="New Report">
                            <font><Font name="System Bold" size="20.0" /></font>
                        </Label>
                        
                        <VBox spacing="5.0">
                            <Label styleClass="field-label" text="Summary / Title" />
                            <TextField fx:id="titleField" promptText="e.g. Illegal dumping in the park" styleClass="search-field" />
                        </VBox>
                        
                        <VBox spacing="5.0">
                            <Label styleClass="field-label" text="Precise Location" />
                            <TextField fx:id="locationField" promptText="Enter address or landmark" styleClass="search-field" />
                        </VBox>
                        
                        <VBox spacing="5.0">
                            <Label styleClass="field-label" text="Environmental Domain" />
                            <ComboBox fx:id="domainComboBox" prefWidth="Infinity" promptText="Select Domain" styleClass="sort-choice-box" />
                        </VBox>

                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                            <Label styleClass="field-label" text="Detailed Description" />
                            <TextArea fx:id="descriptionArea" prefRowCount="6" promptText="Describe the issue in detail..." styleClass="search-field" wrapText="true" />
                        </VBox>

                        <Button onAction="#handleSubmit" prefWidth="Infinity" styleClass="btn-signin" text="🚀 Submit Report" />
                    </children>
                </VBox>

                <!-- My Recent Reports -->
                <VBox spacing="15.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="My Submissions">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <TableView fx:id="myTicketsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colTitle" prefWidth="250.0" text="Title" />
                                <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
                                <TableColumn fx:id="colDate" prefWidth="150.0" text="Date" />
                            </columns>
                        </TableView>
                        <VBox fx:id="notesBox" spacing="5.0" visible="false">
                            <Label style="-fx-text-fill: #bc4749; -fx-font-weight: bold;" text="Admin Feedback:" />
                            <Label fx:id="adminNotesLabel" style="-fx-background-color: #fff5f5; -fx-padding: 10; -fx-border-color: #feb2b2; -fx-border-radius: 5;" wrapText="true" />
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
