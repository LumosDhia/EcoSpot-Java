<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f8faf9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.ticket.TicketMapController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <children>
        <!-- TOP NAV -->
        <HBox alignment="CENTER_LEFT" styleClass="admin-top-bar" spacing="15.0">
            <padding>
                <Insets left="20.0" right="20.0" top="10.0" bottom="10.0" />
            </padding>
            <children>
                <Label styleClass="breadcrumb-text" text="Admin  ›  Interactive Map" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="⬅ Back to Dashboard" />
            </children>
        </HBox>

        <!-- HEADER -->
        <VBox>
            <padding>
                <Insets top="20.0" left="40.0" right="40.0" bottom="10.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" text="📍 Environmental Impact Hotspots" />
                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 14px;" text="Interactive view of all tickets. Red = Pending, Green = Resolved." />
            </children>
        </VBox>

        <!-- MAP CONTAINER -->
        <VBox fx:id="webViewContainer" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">
            <!-- WebView will be injected here dynamically by the controller -->
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="10.0" />
            </padding>
            <style>
                -fx-background-color: transparent;
            </style>
        </VBox>
    </children>
</VBox>
