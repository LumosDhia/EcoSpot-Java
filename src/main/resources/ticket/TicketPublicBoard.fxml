<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="850.0" prefWidth="1200.0" styleClass="admin-content-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.ticket.TicketPublicBoardController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>
    
    <children>
        <!-- TOP BAR (SAME AS WEB) -->
        <VBox>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #1a4332; -fx-padding: 10 20;">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" text="🌿 EcoSpot" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleBackHome" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Home" />
                        <Button style="-fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-background-radius: 15;" text="🎟 Tickets" />
                        <Button onAction="#goToAchievements" style="-fx-background-color: transparent; -fx-text-fill: white;" text="Achievements" />
                        <Button onAction="#goToBlog" style="-fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-background-radius: 5;" text="Blog" />
                    </children>
                </HBox>
                
                <!-- HERO SECTION -->
                <VBox alignment="CENTER" spacing="15.0" styleClass="hero-tickets">
                    <children>
                        <VBox alignment="CENTER" spacing="15.0" styleClass="hero-tickets-overlay">
                            <children>
                                <Label style="-fx-text-fill: white;" text="Community tickets">
                                    <font><Font name="System Bold" size="56.0" /></font>
                                </Label>
                                <Label style="-fx-text-fill: white;" text="Environmental issues and suggestions reported by the community. Pick one and complete it." textAlignment="CENTER" wrapText="true">
                                    <font><Font size="20.0" /></font>
                                </Label>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <Label onMouseClicked="#handleBackHome" style="-fx-text-fill: #fca311; -fx-cursor: hand; -fx-font-weight: bold;" text="Home" />
                                    <Label style="-fx-text-fill: white;" text="/" />
                                    <Label style="-fx-text-fill: white;" text="Tickets" />
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox alignment="TOP_CENTER" spacing="30.0">
                    <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
                    <children>
                        <FlowPane fx:id="ticketsFlow" hgap="25.0" vgap="25.0" alignment="CENTER" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
