<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="800.0" prefWidth="1200.0" styleClass="admin-content-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.ticket.TicketManagementController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>
    
    <children>
        <!-- TOP BAR -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="admin-top-bar">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <Button onAction="#handleBackHome" style="-fx-background-color: transparent; -fx-text-fill: #2d6a4f; -fx-cursor: hand;" text="⬅ Back" />
                <Label styleClass="breadcrumb-text" text="Admin › Environmental Reports (Tickets)" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="10.0">
                    <Label styleClass="admin-profile-name" text="GHACEN" />
                    <Label style="-fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-padding: 5 10; -fx-background-radius: 15;" text="Eco Monitor" />
                </HBox>
            </children>
        </HBox>

        <!-- MAIN CONTENT AREA -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <!-- LEFT SIDE: FORM -->
                <VBox prefWidth="380.0" spacing="15.0" styleClass="stat-card">
                    <children>
                        <Label text="Report Details">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        
                        <VBox spacing="5.0">
                            <Label styleClass="field-label" text="Title" />
                            <TextField fx:id="titleField" promptText="Brief title of the issue" styleClass="search-field" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label styleClass="field-label" text="Location" />
                            <TextField fx:id="locationField" promptText="Address or coordinates" styleClass="search-field" />
                        </VBox>

                        <HBox spacing="10.0">
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="field-label" text="Priority" />
                                <ComboBox fx:id="priorityComboBox" prefWidth="Infinity" styleClass="sort-choice-box" />
                            </VBox>
                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="field-label" text="Domain" />
                                <ComboBox fx:id="domainComboBox" prefWidth="Infinity" styleClass="sort-choice-box" />
                            </VBox>
                        </HBox>

                        <VBox spacing="5.0">
                            <Label styleClass="field-label" text="Status" />
                            <ComboBox fx:id="statusComboBox" prefWidth="Infinity" styleClass="sort-choice-box" />
                        </VBox>
                        
                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                            <Label styleClass="field-label" text="Description" />
                            <TextArea fx:id="descriptionArea" prefRowCount="4" promptText="Detailed description of the environmental issue..." styleClass="search-field" wrapText="true" />
                        </VBox>

                        <Button fx:id="saveButton" onAction="#handleSave" prefWidth="Infinity" styleClass="btn-signin" text="Save Report" />
                        <Button onAction="#handleClear" prefWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #888;" text="Clear Fields" />
                    </children>
                </VBox>

                <!-- RIGHT SIDE: TABLE -->
                <VBox spacing="15.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="Submitted Reports">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <TextField fx:id="searchField" prefWidth="250.0" promptText="Search reports..." styleClass="search-field" />
                            </children>
                        </HBox>
                        
                        <TableView fx:id="ticketTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idCol" prefWidth="40.0" text="ID" />
                                <TableColumn fx:id="titleCol" prefWidth="180.0" text="Title" />
                                <TableColumn fx:id="statusCol" prefWidth="100.0" text="Status" />
                                <TableColumn fx:id="priorityCol" prefWidth="90.0" text="Priority" />
                                <TableColumn fx:id="domainCol" prefWidth="110.0" text="Domain" />
                                <TableColumn fx:id="locationCol" prefWidth="150.0" text="Location" />
                                <TableColumn fx:id="actionsCol" prefWidth="120.0" text="Actions" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
