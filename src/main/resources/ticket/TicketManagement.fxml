<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="720.0" prefWidth="1000.0" styleClass="admin-content-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.ticket.TicketManagementController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>
    
    <children>
        <!-- TOP BAR -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="admin-top-bar">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <Button onAction="#handleBackHome" style="-fx-background-color: transparent; -fx-text-fill: #2d6a4f; -fx-cursor: hand;" text="⬅ Back" />
                <Label styleClass="breadcrumb-text" text="Admin › Ticket Management" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="10.0">
                    <Label styleClass="admin-profile-name" text="GHACEN" />
                    <Label style="-fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-padding: 5 10; -fx-background-radius: 15;" text="Ticket Manager" />
                </HBox>
            </children>
        </HBox>

        <!-- MAIN CONTENT AREA -->
        <HBox spacing="30.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <!-- LEFT SIDE: FORM -->
                <VBox prefWidth="350.0" spacing="20.0" styleClass="stat-card">
                    <children>
                        <Label text="Ticket Details">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>
                        
                        <VBox spacing="5.0">
                            <Label styleClass="field-label" text="Event ID" />
                            <TextField fx:id="eventIdField" promptText="Enter Event ID" styleClass="search-field" />
                        </VBox>
                        
                        <VBox spacing="5.0">
                            <Label styleClass="field-label" text="Price (€)" />
                            <TextField fx:id="priceField" promptText="0.00" styleClass="search-field" />
                        </VBox>
                        
                        <VBox spacing="5.0">
                            <Label styleClass="field-label" text="Ticket Type" />
                            <ComboBox fx:id="typeComboBox" prefWidth="Infinity" promptText="Select Type" styleClass="sort-choice-box" />
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />
                        
                        <Button fx:id="saveButton" onAction="#handleSave" prefWidth="Infinity" styleClass="btn-signin" text="Save Ticket" />
                        <Button fx:id="clearButton" onAction="#handleClear" prefWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #888;" text="Clear Fields" />
                    </children>
                </VBox>

                <!-- RIGHT SIDE: TABLE -->
                <VBox spacing="20.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="Available Tickets">
                                    <font>
                                        <Font name="System Bold" size="20.0" />
                                    </font>
                                </Label>
                                <Region HBox.hgrow="ALWAYS" />
                                <TextField fx:id="searchField" promptText="Search tickets..." styleClass="search-field" />
                            </children>
                        </HBox>
                        
                        <TableView fx:id="ticketTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idCol" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="eventIdCol" prefWidth="100.0" text="Event ID" />
                                <TableColumn fx:id="priceCol" prefWidth="100.0" text="Price" />
                                <TableColumn fx:id="typeCol" prefWidth="150.0" text="Type" />
                                <TableColumn fx:id="actionsCol" prefWidth="150.0" text="Actions" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
