<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #f0f7f4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.ticket.CompleteTicketController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>
    <children>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 12 20; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
            <children>
                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 14px;" text="Tickets  ›  " />
                <Label style="-fx-text-fill: #1f2937; -fx-font-size: 14px; -fx-font-weight: bold;" text="Submit completion proof" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <VBox spacing="18.0" maxWidth="760.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 3);">
            <VBox.margin><Insets top="30.0" left="40.0" right="40.0" /></VBox.margin>
            <children>
                <Label style="-fx-text-fill: #1f2937; -fx-font-size: 22px; -fx-font-weight: bold;" text="I completed this ticket" />
                <Label fx:id="ticketTitleLabel" style="-fx-text-fill: #2d6a4f; -fx-font-size: 15px; -fx-font-weight: bold;" text="Ticket title" />
                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 13px;" text="Provide what you did and attach an image proof. Admin will review before moving this ticket to achievements." wrapText="true" />

                <VBox spacing="8.0">
                    <children>
                        <Label style="-fx-text-fill: #374151; -fx-font-size: 13px; -fx-font-weight: bold;" text="Completion description" />
                        <TextArea fx:id="completionDescriptionInput" prefRowCount="5" promptText="Explain what you did to complete this ticket..." wrapText="true" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label style="-fx-text-fill: #374151; -fx-font-size: 13px; -fx-font-weight: bold;" text="Proof image" />
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button onAction="#chooseProofImage" styleClass="btn-outline" text="Choose File" />
                                <Label fx:id="fileNameLabel" style="-fx-text-fill: #6b7280;" text="No file chosen" />
                            </children>
                        </HBox>
                        <ImageView fx:id="proofPreview" fitHeight="160.0" fitWidth="280.0" preserveRatio="true" style="-fx-border-color: #e5e7eb; -fx-border-width: 1;" />
                    </children>
                </VBox>

                <Label fx:id="errorLabel" managed="false" style="-fx-text-fill: #ef4444; -fx-font-size: 12px; -fx-font-weight: bold;" visible="false" />

                <HBox alignment="CENTER_RIGHT" spacing="12.0" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <Button onAction="#cancel" styleClass="btn-light" text="Cancel" />
                        <Button onAction="#submitCompletion" styleClass="btn-primary" text="Submit for Admin Review" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>

