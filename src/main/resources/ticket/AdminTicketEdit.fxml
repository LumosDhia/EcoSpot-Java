<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>

<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #f8faf9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.ticket.AdminTicketEditController">
    <stylesheets>
        <URL value="@../style.css" />
        <URL value="@../ticket-style.css" />
    </stylesheets>

    <children>
        <HBox alignment="CENTER_LEFT" styleClass="admin-top-bar" spacing="15.0">
            <padding>
                <Insets left="20.0" right="20.0" top="10.0" bottom="10.0" />
            </padding>
            <children>
                <Label styleClass="breadcrumb-text" text="Admin  ›  Edit Ticket" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <VBox alignment="CENTER_RIGHT">
                            <children>
                                <Label fx:id="userNameLabel" styleClass="admin-profile-name" text="Admin" />
                            </children>
                        </VBox>
                        <Label text="👤" style="-fx-font-size: 32px; -fx-background-color: #fca311; -fx-text-fill: white; -fx-padding: 5; -fx-background-radius: 50;" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <ScrollPane fx:id="mainScrollPane" fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox alignment="TOP_CENTER" spacing="20.0">
                    <padding><Insets bottom="40.0" left="40.0" right="40.0" top="30.0" /></padding>
                    <children>
                        
                        <HBox alignment="CENTER_LEFT" spacing="10.0" maxWidth="1000.0">
                            <children>
                                <Button onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #4b5563; -fx-font-weight: bold; -fx-cursor: hand;" text="← Back to Tickets" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" text="Administrative Ticket Edition" />
                            </children>
                        </HBox>

                        <HBox spacing="20.0" maxWidth="1000.0">
                            <children>
                                <!-- LEFT COLUMN -->
                                <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <!-- Core Information -->
                                        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-padding: 20;" spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 16px;" text="Core Information" />
                                                <VBox spacing="8.0">
                                                    <children>
                                                        <Label style="-fx-text-fill: #4b5563; -fx-font-size: 12px; -fx-font-weight: bold;" text="TICKET TITLE" />
                                                        <TextField fx:id="titleInput" style="-fx-padding: 10; -fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-radius: 4;" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="8.0">
                                                    <children>
                                                        <Label style="-fx-text-fill: #4b5563; -fx-font-size: 12px; -fx-font-weight: bold;" text="DESCRIPTION" />
                                                        <TextArea fx:id="descriptionInput" prefRowCount="4" style="-fx-padding: 5; -fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-radius: 4;" wrapText="true" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <!-- Location -->
                                        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-padding: 20;" spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #ef4444; -fx-font-size: 16px;" text="Location" />
                                                <VBox spacing="8.0">
                                                    <children>
                                                        <HBox spacing="10.0">
                                                            <children>
                                                                <TextField fx:id="locationInput" promptText="Search for a place..." HBox.hgrow="ALWAYS" style="-fx-padding: 10; -fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-radius: 4;" />
                                                                <Button fx:id="searchLocationBtn" onAction="#handleLocationSearch" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 4;" text="Find" />
                                                            </children>
                                                        </HBox>
                                                        <ListView fx:id="locationResultsList" visible="false" managed="false" prefHeight="100.0" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <!-- Action Plan & Tasks -->
                                        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-padding: 20;" spacing="15.0">
                                            <children>
                                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                    <children>
                                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #10b981; -fx-font-size: 16px;" text="Action Plan &amp; Tasks" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Button fx:id="aiSuggestBtn" onAction="#handleAiSuggest" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 15;" text="✨ AI Refine" />
                                                    </children>
                                                </HBox>
                                                <VBox fx:id="consignesContainer" spacing="10.0" />
                                                <Button onAction="#handleAddConsigne" style="-fx-background-color: white; -fx-border-color: #10b981; -fx-border-radius: 4; -fx-text-fill: #10b981;" text="+ Add Manual Step" />
                                            </children>
                                        </VBox>

                                        <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-padding: 10 0;">
                                            <children>
                                                <Button fx:id="saveBtn" onAction="#handleSave" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 30; -fx-background-radius: 20;" text="Save All Changes" />
                                                <Button onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #6b7280;" text="Discard and Exit" />
                                            </children>
                                        </HBox>
                                        <Label fx:id="errorLabel" style="-fx-text-fill: #ef4444;" visible="false" managed="false" />
                                    </children>
                                </VBox>

                                <!-- RIGHT COLUMN -->
                                <VBox spacing="20.0" prefWidth="350.0" minWidth="350.0">
                                    <children>
                                        <!-- Admin Controls -->
                                        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-padding: 20;" spacing="15.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #6366f1; -fx-font-size: 16px;" text="Admin Controls" />
                                                <Label fx:id="aiSpamLabel" style="-fx-background-color: #fee2e2; -fx-text-fill: #ef4444; -fx-padding: 5 10; -fx-background-radius: 10; -fx-font-size: 12px; -fx-font-weight: bold;" text="🚨 AI FLAGGED SPAM" visible="false" managed="false" />
                                                
                                                <VBox spacing="5.0">
                                                    <children>
                                                        <Label style="-fx-text-fill: #4b5563; -fx-font-size: 12px; -fx-font-weight: bold;" text="STATUS" />
                                                        <ComboBox fx:id="statusCombo" prefWidth="MAX_VALUE" style="-fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-radius: 4;" />
                                                    </children>
                                                </VBox>
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-text-fill: #4b5563; -fx-font-size: 12px; -fx-font-weight: bold;" text="PRIORITY" />
                                                                <ComboBox fx:id="priorityCombo" prefWidth="MAX_VALUE" style="-fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-radius: 4;" />
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-text-fill: #4b5563; -fx-font-size: 12px; -fx-font-weight: bold;" text="DOMAIN" />
                                                                <ComboBox fx:id="domainCombo" prefWidth="MAX_VALUE" style="-fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-radius: 4;" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                                <VBox spacing="5.0">
                                                    <children>
                                                        <Label style="-fx-text-fill: #4b5563; -fx-font-size: 12px; -fx-font-weight: bold;" text="ASSIGNED NGO" />
                                                        <ComboBox fx:id="ngoCombo" prefWidth="MAX_VALUE" promptText="Unassigned" style="-fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-radius: 4;" />
                                                        <Label fx:id="aiNgoLabel" style="-fx-text-fill: #10b981; -fx-font-size: 11px;" visible="false" managed="false" />
                                                    </children>
                                                </VBox>
                                                <CheckBox fx:id="isSpamCheck" text="Mark as Protected/Spam" style="-fx-text-fill: #ef4444; -fx-font-weight: bold;" />
                                            </children>
                                        </VBox>

                                        <!-- Image Card -->
                                        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-padding: 20;" spacing="10.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #3b82f6; -fx-font-size: 16px;" text="Ticket Image" />
                                                <ImageView fx:id="ticketImageView" fitWidth="310.0" fitHeight="200.0" preserveRatio="true" visible="false" managed="false" />
                                                <HBox alignment="CENTER_LEFT" spacing="0.0">
                                                    <children>
                                                        <Button onAction="#handleChooseFile" style="-fx-background-color: #e5e7eb; -fx-text-fill: #374151; -fx-padding: 5 10; -fx-background-radius: 4 0 0 4;" text="Choose File" />
                                                        <Label fx:id="fileNameLabel" style="-fx-text-fill: #6b7280; -fx-padding: 0 10; -fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-radius: 0 4 4 0;" text="No file chosen" HBox.hgrow="ALWAYS" maxWidth="MAX_VALUE" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <!-- Admin Notes -->
                                        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2); -fx-padding: 20;" spacing="10.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #f59e0b; -fx-font-size: 16px;" text="Private Admin Notes" />
                                                <TextArea fx:id="adminNotesInput" prefRowCount="3" promptText="Your notes or feedback..." style="-fx-padding: 5; -fx-background-color: #f9fafb; -fx-border-color: #e5e7eb; -fx-border-radius: 4;" wrapText="true" />
                                                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 11px;" text="Visible to reporter if sent back." />
                                            </children>
                                        </VBox>

                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
