<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #f8faf9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.ticket.PendingTicketsController">
    <stylesheets>
        <URL value="@../style.css" />
        <URL value="@../ticket-style.css" />
    </stylesheets>

    <children>
        <!-- TOP NAV -->
        <HBox alignment="CENTER_LEFT" styleClass="admin-top-bar" spacing="15.0">
            <padding>
                <Insets left="20.0" right="20.0" top="10.0" bottom="10.0" />
            </padding>
            <children>
                <Label styleClass="breadcrumb-text" text="Admin  ›  Pending Tickets" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Label text="🔔" style="-fx-font-size: 20px;" />
                        <VBox alignment="CENTER_RIGHT">
                            <children>
                                <Label fx:id="userNameLabel" styleClass="admin-profile-name" text="Admin" />
                                <Label styleClass="admin-profile-role" text="Verified Administrator" />
                            </children>
                        </VBox>
                        <Label text="👤" style="-fx-font-size: 32px; -fx-background-color: #fca311; -fx-text-fill: white; -fx-padding: 5; -fx-background-radius: 50;" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- HEADER SECTION -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 15;">
            <VBox.margin>
                <Insets left="40.0" right="40.0" top="30.0" bottom="20.0" />
            </VBox.margin>
            <padding>
                <Insets top="25.0" bottom="25.0" left="30.0" right="30.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a4a38;" text="Pending Tickets Queue" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" text="Review user submissions. Publish them to the community board, refuse spam, or send them back for revision." />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
                
                <Region prefHeight="20.0" />
                
                <!-- Instruction Bar -->
                <HBox style="-fx-background-color: #fffbeb; -fx-border-color: #fcd34d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 10;">
                    <children>
                        <Label style="-fx-text-fill: #b45309; -fx-font-size: 13px; -fx-font-weight: bold;" text="Action required:" />
                        <Region prefWidth="10.0" />
                        <Label style="-fx-text-fill: #92400e; -fx-font-size: 13px;" text="Pending tickets are hidden from the public until you manually review and publish them." />
                    </children>
                </HBox>

                <Region prefHeight="20.0" />

                <!-- LIST CONTENT -->
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="ticketsListContainer" spacing="15.0" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>

        <!-- FOOTER BUTTONS -->
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <padding>
                <Insets left="40.0" bottom="20.0" />
            </padding>
            <children>
                <Button onAction="#goToDashboard" text="⬅ Back to Dashboard" style="-fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-text-fill: #4b5563; -fx-cursor: hand;" />
            </children>
        </HBox>
    </children>
</VBox>
