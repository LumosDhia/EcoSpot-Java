<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #f0f7f4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.ticket.CreateTicketController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <children>
        <!-- TOP NAV -->
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 10 20 10 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <children>
                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 14px;" text="User  ›  " />
                <Label style="-fx-text-fill: #1f2937; -fx-font-weight: bold; -fx-font-size: 14px;" text="Create a ticket" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <VBox alignment="CENTER_RIGHT">
                            <children>
                                <Label fx:id="userNameLabel" style="-fx-font-weight: bold; -fx-text-fill: #1f2937;" text="User" />
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #6b7280;" text="Verified Citizen" />
                            </children>
                        </VBox>
                        <Label style="-fx-font-size: 24px; -fx-background-color: #fca311; -fx-text-fill: white; -fx-padding: 8; -fx-background-radius: 50;" text="👤" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox alignment="TOP_CENTER" spacing="20.0">
                    <padding><Insets bottom="40.0" left="40.0" right="40.0" top="30.0" /></padding>
                    <children>
                        
                        <!-- Back to dashboard -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0" maxWidth="800.0">
                            <children>
                                <Button onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #2b8b54; -fx-font-weight: bold; -fx-cursor: hand;" text="← Back to Dashboard" />
                            </children>
                        </HBox>

                        <!-- FORM CONTAINER -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);" maxWidth="800.0">
                            <children>
                                <!-- Form Header -->
                                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #3b8e61; -fx-background-radius: 10 10 0 0; -fx-padding: 20;">
                                    <children>
                                        <Label style="-fx-font-size: 32px; -fx-background-color: white; -fx-text-fill: #3b8e61; -fx-background-radius: 50; -fx-padding: 5 10 5 10;" text="🍃" />
                                        <VBox>
                                            <children>
                                                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Submit an Environmental Ticket" />
                                                <Label style="-fx-text-fill: #d1fae5; -fx-font-size: 14px;" text="Report an Issue or suggest an Improvement" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Form Body -->
                                <VBox spacing="25.0" style="-fx-padding: 30;">
                                    <children>
                                        
                                        <!-- Instruction Alert -->
                                        <HBox style="-fx-background-color: #f0fdf4; -fx-border-color: #15803d; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 15; -fx-border-width: 2;">
                                            <children>
                                                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 14px;" text="ⓘ Describe your environmental observation. You must search and select a location so we can show the 7-day weather forecast on your ticket." wrapText="true" />
                                            </children>
                                        </HBox>

                                        <!-- Ticket Title -->
                                        <VBox spacing="8.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #1f2937; -fx-font-size: 14px;" text="Ticket Title" />
                                                <TextField fx:id="titleInput" promptText="Short title (min 5 characters)" style="-fx-padding: 10; -fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-font-size: 14px;" />
                                                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 12px;" text="✎ Give your report a clear, concise name." />
                                            </children>
                                        </VBox>

                                        <!-- Details & Description -->
                                        <VBox spacing="8.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #1f2937; -fx-font-size: 14px;" text="Details &amp; Description" />
                                                <TextArea fx:id="descriptionInput" promptText="Describe the issue in detail (min 20 characters)" prefRowCount="5" style="-fx-padding: 5; -fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-font-size: 14px;" wrapText="true" />
                                            </children>
                                        </VBox>

                                        <!-- Dynamic Consignes Section -->
                                        <VBox spacing="8.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #1f2937; -fx-font-size: 14px;" text="Specific Instructions (Consignes)" />
                                                <VBox fx:id="consignesContainer" spacing="10.0">
                                                    <!-- Dynamic rows will be added here -->
                                                </VBox>
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <Button onAction="#handleAddConsigne" style="-fx-background-color: #f3f4f6; -fx-text-fill: #374151; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 4; -fx-cursor: hand; -fx-border-color: #d1d5db; -fx-border-radius: 4;" text="+ Manual Task" />
                                                        <Button fx:id="aiSuggestBtn" onAction="#handleAiSuggest" style="-fx-background-color: #ecfdf5; -fx-text-fill: #059669; -fx-font-weight: bold; -fx-padding: 8 15; -fx-background-radius: 4; -fx-cursor: hand; -fx-border-color: #10b981; -fx-border-radius: 4;" text="✨ AI Suggest Tasks" />
                                                    </children>
                                                </HBox>
                                                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 12px;" text="✎ Break down the task into clear, simple steps." />
                                            </children>
                                        </VBox>
                                        
                                        <!-- Location (Implicitly required according to alert) -->
                                        <!-- Location Search -->
                                        <VBox spacing="8.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #1f2937; -fx-font-size: 14px;" text="Location *" />
                                                <HBox spacing="10.0">
                                                    <children>
                                                        <TextField fx:id="locationInput" promptText="Search for a place (e.g. Paris, Central Park)" HBox.hgrow="ALWAYS" style="-fx-padding: 10; -fx-background-color: white; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-font-size: 14px;" />
                                                        <Button fx:id="searchLocationBtn" onAction="#handleLocationSearch" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 4; -fx-cursor: hand;" text="Search" />
                                                    </children>
                                                </HBox>
                                                <ListView fx:id="locationResultsList" visible="false" managed="false" prefHeight="150.0" style="-fx-background-radius: 4; -fx-border-color: #d1d5db;" />
                                                <Label style="-fx-text-fill: #6b7280; -fx-font-size: 12px;" text="📍 Tip: Search and select a precise location for accurate weather data." />
                                            </children>
                                        </VBox>

                                        <!-- Upload Photo -->
                                        <VBox spacing="8.0">
                                            <children>
                                                <Label style="-fx-font-weight: bold; -fx-text-fill: #1f2937; -fx-font-size: 14px;" text="Upload Photo (Optional)" />
                                                <HBox alignment="CENTER_LEFT" spacing="0.0" style="-fx-background-color: #f3f4f6; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 0;">
                                                    <children>
                                                        <Button onAction="#handleChooseFile" style="-fx-background-color: #e5e7eb; -fx-text-fill: #374151; -fx-font-weight: bold; -fx-padding: 10 15; -fx-background-radius: 4 0 0 4; -fx-cursor: hand;" text="📷 Choose File" />
                                                        <Label fx:id="fileNameLabel" style="-fx-text-fill: #6b7280; -fx-padding: 0 15;" text="No file chosen" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                        
                                        <!-- Error Label -->
                                        <Label fx:id="errorLabel" style="-fx-text-fill: #e53e3e; -fx-font-weight: bold; -fx-font-size: 12px;" visible="false" managed="false" />

                                        <!-- ACTION BUTTONS (As requested by user) -->
                                        <HBox spacing="15.0" alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0; -fx-border-color: #e5e7eb transparent transparent transparent;">
                                            <children>
                                                <Button onAction="#goBack" style="-fx-background-color: transparent; -fx-border-color: #d1d5db; -fx-border-radius: 4; -fx-text-fill: #4b5563; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20; -fx-cursor: hand;" text="Cancel" />
                                                <Button onAction="#handleSubmit" style="-fx-background-color: #2b8b54; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 30; -fx-background-radius: 4; -fx-cursor: hand;" text="Send Ticket ➔" />
                                            </children>
                                        </HBox>

                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
