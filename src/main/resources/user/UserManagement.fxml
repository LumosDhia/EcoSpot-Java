<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #f8faf9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.user.UserManagementController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <children>
        <!-- TOP NAV -->
        <HBox alignment="CENTER_LEFT" styleClass="admin-top-bar" spacing="15.0">
            <padding>
                <Insets left="20.0" right="20.0" top="10.0" bottom="10.0" />
            </padding>
            <children>
                <Label styleClass="breadcrumb-text" text="Admin  ›  Users Management" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Label text="🔔" style="-fx-font-size: 20px;" />
                        <VBox alignment="CENTER_RIGHT">
                            <children>
                                <Label styleClass="admin-profile-name" text="Admin" />
                                <Label styleClass="admin-profile-role" text="Verified Citizen" />
                            </children>
                        </VBox>
                        <Label text="👤" style="-fx-font-size: 32px; -fx-background-color: #fca311; -fx-text-fill: white; -fx-padding: 5; -fx-background-radius: 50;" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- HEADER SECTION -->
        <VBox styleClass="section-card">
            <VBox.margin>
                <Insets left="40.0" right="40.0" top="30.0" bottom="20.0" />
            </VBox.margin>
            <padding>
                <Insets top="25.0" bottom="25.0" left="30.0" right="30.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="page-title" text="User Directory" />
                                <Label styleClass="section-hint" text="Manage roles, set restrictions, and organize platform members." />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#goToCreateUser" styleClass="btn-create-user" text="✚ Create New User" />
                    </children>
                </HBox>

                <Region prefHeight="30.0" />

                <HBox styleClass="user-table-header" spacing="0.0" alignment="CENTER_LEFT">
                    <children>
                        <Label styleClass="table-header-cell" text="IDENTITY" prefWidth="300.0" />
                        <Label styleClass="table-header-cell" text="USER TYPE" prefWidth="250.0" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label alignment="CENTER_RIGHT" prefWidth="150.0" styleClass="table-header-cell" text="MANAGEMENT" />
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                    <content>
                        <VBox fx:id="userListContainer" spacing="1.0" />
                    </content>
                </ScrollPane>
            </children>
        </VBox>

        <!-- FOOTER BUTTONS -->
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <padding>
                <Insets left="40.0" bottom="20.0" />
            </padding>
            <children>
                <Button onAction="#goToDashboard" styleClass="btn-outline" text="⬅ Back to Dashboard" />
            </children>
        </HBox>
    </children>
</VBox>
