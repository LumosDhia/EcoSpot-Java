<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #f7fafc;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.user.FaceLoginController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <Label text="Face ID Login">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <Label text="Position your face in front of the camera" textFill="#718096" />

        <StackPane prefHeight="300.0" prefWidth="300.0" style="-fx-background-color: #000; -fx-background-radius: 10;">
            <children>
                <ImageView fx:id="webcamView" fitHeight="300.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" />
                <ProgressIndicator fx:id="loadingIndicator" visible="false" />
            </children>
        </StackPane>

        <Label fx:id="statusLabel" text="Camera starting..." textFill="#4a5568" />

        <VBox spacing="10.0" alignment="CENTER">
            <children>
                <Button fx:id="scanBtn" disable="true" maxWidth="Infinity" onAction="#handleScan" style="-fx-background-color: #2d6a4f; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 6; -fx-cursor: hand;" text="Scan &amp; Log In" />
                <Button maxWidth="Infinity" onAction="#handleCancel" style="-fx-background-color: transparent; -fx-text-fill: #e53e3e; -fx-cursor: hand;" text="Cancel" />
            </children>
        </VBox>
    </children>
</VBox>
