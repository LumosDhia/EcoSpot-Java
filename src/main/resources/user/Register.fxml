<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.user.RegisterController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <top>
        <VBox>
            <!-- ===== TOP DARK BAR ===== -->
            <HBox alignment="CENTER_LEFT" styleClass="top-bar" spacing="20.0">
                <padding><Insets left="20.0" right="20.0" top="8.0" bottom="8.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHome" style="-fx-cursor: hand;" styleClass="top-bar-brand" text="🌿 EcoSpot" />
                    <Button styleClass="top-bar-link" text="🔑 Login" onAction="#goToLogin" />
                    <Button styleClass="top-bar-link" text="👤 Register" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button styleClass="top-bar-link" text="🌐 EN ▾" />
                    <Button styleClass="top-bar-link" text="🏠" onAction="#goToHome" />
                </children>
            </HBox>

            <!-- ===== WHITE SECONDARY NAV ===== -->
            <HBox alignment="CENTER_LEFT" styleClass="main-nav" spacing="15.0">
                <padding><Insets left="20.0" right="20.0" top="12.0" bottom="12.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHome" style="-fx-cursor: hand;" styleClass="brand-name" text="EcoSpot" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button styleClass="nav-link-btn" text="Home" onAction="#goToHome" />
                    <Button onAction="#goToEvents" styleClass="nav-link-btn" text="Events" />
                    <Button onAction="#goToTickets" styleClass="nav-link-btn-active" text="🎟 Tickets" />
                    <Button onAction="#goToAchievements" styleClass="nav-link-btn" text="Achievements" />
                    <Button onAction="#goToBlog" styleClass="nav-btn-blog" text="Blog" />
                </children>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f0f7f4; -fx-background: #f0f7f4;">
            <content>
                <VBox alignment="CENTER" spacing="30.0">
                    <padding><Insets top="40.0" bottom="40.0" /></padding>
                    <children>
                        <VBox styleClass="register-card" spacing="15.0">
                            <children>
                                <VBox alignment="CENTER" spacing="5.0">
                                    <children>
                                        <Label text="Register" styleClass="login-title" />
                                        <Label fx:id="errorLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 13px;" visible="false" managed="false" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Email" styleClass="field-label" />
                                        <TextField fx:id="emailField" promptText="Email" styleClass="login-input" />
                                    </children>
                                </VBox>

                                <HBox spacing="15.0">
                                    <children>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="First name" styleClass="field-label" />
                                                <TextField fx:id="firstNameField" promptText="First name" styleClass="login-input" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Last name" styleClass="field-label" />
                                                <TextField fx:id="lastNameField" promptText="Last name" styleClass="login-input" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Address" styleClass="field-label" />
                                        <TextField fx:id="addressField" promptText="Address" styleClass="login-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="ZIP code" styleClass="field-label" />
                                        <TextField fx:id="zipCodeField" promptText="e.g. 75001" styleClass="login-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="City" styleClass="field-label" />
                                        <TextField fx:id="cityField" promptText="City" styleClass="login-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Password" styleClass="field-label" />
                                        <PasswordField fx:id="passwordField" promptText="Password" styleClass="login-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Repeat password" styleClass="field-label" />
                                        <PasswordField fx:id="repeatPasswordField" promptText="Repeat password" styleClass="login-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="10.0" style="-fx-background-color: #f7fafc; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #cbd5e0; -fx-border-radius: 8;">
                                    <children>
                                        <Label text="Robot Verification" styleClass="field-label" />
                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                            <children>
                                                <ImageView fx:id="captchaImageView" fitHeight="40.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" />
                                                <Button text="🔄" onAction="#refreshCaptcha" style="-fx-background-color: transparent; -fx-cursor: hand;" />
                                                <TextField fx:id="captchaField" promptText="Enter code" styleClass="login-input" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <CheckBox fx:id="termsCheckBox" text="I agree to the terms and conditions" styleClass="terms-checkbox" />

                                <VBox spacing="15.0">
                                    <children>
                                        <Button text="📸 Add Face ID (Optional)" onAction="#handleFaceEnroll" maxWidth="Infinity" 
                                                style="-fx-background-color: #f7fafc; -fx-border-color: #cbd5e0; -fx-text-fill: #2d3748; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 4; -fx-border-radius: 4; -fx-cursor: hand;" />
                                        <Button fx:id="registerBtn" text="Register" styleClass="btn-signin" maxWidth="Infinity" onAction="#handleRegister" />
                                        <Button text="Already have an account? Sign in" styleClass="btn-register-outline" maxWidth="Infinity" onAction="#goToLogin" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
