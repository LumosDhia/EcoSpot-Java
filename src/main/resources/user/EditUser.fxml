<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #f8faf9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.user.EditUserController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <children>
        <!-- TOP NAV -->
        <HBox alignment="CENTER_LEFT" styleClass="admin-top-bar" spacing="15.0">
            <padding>
                <Insets left="20.0" right="20.0" top="10.0" bottom="10.0" />
            </padding>
            <children>
                <Label styleClass="breadcrumb-text" text="Admin  ›  Change user type" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Label text="🔔" style="-fx-font-size: 20px;" />
                        <VBox alignment="CENTER_RIGHT">
                            <children>
                                <Label styleClass="admin-profile-name" text="Admin" />
                                <Label styleClass="admin-profile-role" text="Verified Citizen" />
                            </children>
                        </VBox>
                        <Label text="👤" style="-fx-font-size: 32px; -fx-background-color: #fca311; -fx-text-fill: white; -fx-padding: 5; -fx-background-radius: 50;" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <VBox VBox.vgrow="NEVER" spacing="15.0">
            <VBox.margin>
                <Insets left="40.0" right="40.0" top="30.0" bottom="20.0" />
            </VBox.margin>

            <!-- USER INFO CARD -->
            <VBox styleClass="section-card">
                <padding>
                    <Insets top="20.0" bottom="20.0" left="25.0" right="25.0" />
                </padding>
                <children>
                    <Label fx:id="userInfoLabel" styleClass="section-heading" text="user@example.com — Name" />
                </children>
            </VBox>

            <!-- ROLE EDIT CARD -->
            <VBox styleClass="section-card" spacing="20.0">
                <padding>
                    <Insets top="30.0" bottom="30.0" left="25.0" right="25.0" />
                </padding>
                <children>
                    <Label fx:id="errorLabel" style="-fx-text-fill: #e53e3e; -fx-font-size: 14px; -fx-font-weight: bold;" visible="false" managed="false" />

                    <VBox spacing="8.0">
                        <Label styleClass="field-label" text="User type" />
                        <ComboBox fx:id="roleComboBox" maxWidth="Infinity" styleClass="form-input" />
                    </VBox>

                    <Region prefHeight="5.0" />

                    <HBox spacing="15.0">
                        <Button onAction="#handleSave" styleClass="btn,btn-secondary" text="Save" />
                        <Button onAction="#handleCancel" styleClass="btn-outline" text="Cancel" />
                    </HBox>
                </children>
            </VBox>
        </VBox>
    </children>
</VBox>
