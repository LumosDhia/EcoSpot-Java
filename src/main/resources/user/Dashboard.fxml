<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.user.DashboardController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>
    
    <children>
        <!-- SIDEBAR -->
        <VBox styleClass="admin-sidebar" HBox.hgrow="NEVER">
            <children>
                <Label styleClass="sidebar-logo-text" text="EcoSpot" />
                <Label fx:id="sidebarRoleLabel" styleClass="sidebar-role-text" text="DASHBOARD" />
                
                <VBox spacing="5.0">
                    <children>
                        <Button onAction="#handleLogout" styleClass="sidebar-item" text="⬅ Public site" />
                        <Region prefHeight="20.0" />
                        <Button styleClass="sidebar-item-active" text="🏠 Dashboard" />
                        
                        <!-- ADMIN SIDEBAR LINKS -->
                        <VBox fx:id="adminSidebarLinks" spacing="5.0" visible="false" managed="false">
                            <children>
                                <Button onAction="#goToBlogManagement" styleClass="sidebar-item" text="📰 Articles" />
                                <Button styleClass="sidebar-item" text="💬 Comments" />
                                <Button styleClass="sidebar-item" text="📅 Events" />
                                <Button onAction="#goToPendingTickets" styleClass="sidebar-item" text="🎫 Pending tickets" />
                                <Button styleClass="sidebar-item" text="📋 All tickets" />
                                <Button styleClass="sidebar-item" text="✅ Completions" />
                                <Button onAction="#goToUserManagement" styleClass="sidebar-item" text="👥 Users" />
                                <Button styleClass="sidebar-item" text="🤝 Sponsors" />
                            </children>
                        </VBox>

                        <!-- NGO SIDEBAR LINKS -->
                        <VBox fx:id="ngoSidebarLinks" spacing="5.0" visible="false" managed="false">
                            <children>
                                <Button onAction="#goToBlogManagement" styleClass="sidebar-item" text="📰 My articles" />
                                <Button styleClass="sidebar-item" text="💬 Comments" />
                                <Button styleClass="sidebar-item" text="📅 My events" />
                            </children>
                        </VBox>

                        <!-- USER SIDEBAR LINKS -->
                        <VBox fx:id="userSidebarLinks" spacing="5.0" visible="false" managed="false">
                            <children>
                                <Button onAction="#goToMyTickets" styleClass="sidebar-item" text="📋 My tickets" />
                                <Button onAction="#goToCreateTicket" styleClass="sidebar-item" text="➕ New ticket" />
                                <Button styleClass="sidebar-item" text="🌐 Community tickets" />
                                <Button styleClass="sidebar-item" text="🏆 Achievements" />
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets left="15.0" right="15.0" />
                    </padding>
                </VBox>
            </children>
        </VBox>

        <!-- MAIN CONTENT -->
        <VBox styleClass="admin-content-bg" HBox.hgrow="ALWAYS">
            <children>
                <!-- TOP HEADER -->
                <HBox alignment="CENTER_LEFT" styleClass="admin-top-bar">
                    <children>
                        <Label fx:id="breadcrumbLabel" styleClass="breadcrumb-text" text="Admin  ›  Dashboard" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <StackPane>
                                    <children>
                                        <Label text="🔔" style="-fx-font-size: 20px;" />
                                        <Label fx:id="notificationBadge" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 9px; -fx-padding: 1 4; -fx-background-radius: 10;" text="0" StackPane.alignment="TOP_RIGHT">
                                            <StackPane.margin>
                                                <Insets top="-5.0" right="-5.0" />
                                            </StackPane.margin>
                                        </Label>
                                    </children>
                                </StackPane>
                                <VBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Label fx:id="userNameLabel" styleClass="admin-profile-name" text="User" />
                                        <Label fx:id="userSubRoleLabel" styleClass="admin-profile-role" text="Verified Citizen" />
                                    </children>
                                </VBox>
                                <Label text="👤" style="-fx-font-size: 32px; -fx-background-color: #fca311; -fx-text-fill: white; -fx-padding: 5; -fx-background-radius: 50;" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <Label fx:id="dashboardInstructionLabel" styleClass="admin-dashboard-title" text="..." />

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <StackPane>
                            <children>
                                <!-- ADMIN CARDS GRID -->
                                <FlowPane fx:id="adminCardsGrid" hgap="25.0" vgap="25.0" styleClass="dashboard-grid" visible="false" managed="false">
                                    <children>
                                        <VBox onMouseClicked="#goToPendingTicketsGrid" styleClass="stat-card">
                                            <children>
                                                <VBox alignment="CENTER" spacing="15.0">
                                                    <children>
                                                        <Label text="🕒" style="-fx-font-size: 30px; -fx-text-fill: #2d6a4f;" />
                                                        <Label styleClass="card-title-lg" text="Pending tickets" />
                                                        <Label styleClass="card-subtitle" text="Review, publish, refuse or send back tickets" textAlignment="CENTER" wrapText="true" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                        <VBox styleClass="stat-card">
                                            <children>
                                                <VBox alignment="CENTER" spacing="15.0">
                                                    <children>
                                                        <Label text="✔️" style="-fx-font-size: 30px; -fx-text-fill: #2d6a4f;" />
                                                        <Label styleClass="card-title-lg" text="Completions" />
                                                        <Label styleClass="card-subtitle" text="Mark ticket completions as achieved" textAlignment="CENTER" wrapText="true" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                        <VBox onMouseClicked="#goToBlogManagementGrid" styleClass="stat-card">
                                            <children>
                                                <StackPane alignment="TOP_RIGHT">
                                                    <children>
                                                        <Label styleClass="stat-badge" text="12" />
                                                        <VBox alignment="CENTER" spacing="15.0">
                                                            <children>
                                                                <Label text="📰" style="-fx-font-size: 30px;" />
                                                                <Label styleClass="card-title-lg" text="Articles" />
                                                                <Label styleClass="card-subtitle" text="Manage blog articles (all authors)" textAlignment="CENTER" wrapText="true" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </VBox>
                                        <VBox onMouseClicked="#handleCardClick" styleClass="stat-card">
                                            <children>
                                                <StackPane alignment="TOP_RIGHT">
                                                    <children>
                                                        <Label styleClass="stat-badge" text="187" />
                                                        <VBox alignment="CENTER" spacing="15.0">
                                                            <children>
                                                                <Label text="👥" style="-fx-font-size: 30px;" />
                                                                <Label styleClass="card-title-lg" text="Users" />
                                                                <Label styleClass="card-subtitle" text="Create users and manage roles" textAlignment="CENTER" wrapText="true" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </VBox>
                                    </children>
                                </FlowPane>

                                <!-- NGO CARDS GRID -->
                                <FlowPane fx:id="ngoCardsGrid" hgap="25.0" vgap="25.0" styleClass="dashboard-grid" visible="false" managed="false">
                                    <children>
                                        <!-- Create article -->
                                        <VBox onMouseClicked="#goToCreateArticleGrid" styleClass="stat-card">
                                            <children>
                                                <StackPane alignment="TOP_RIGHT">
                                                    <children>
                                                        <Label styleClass="stat-badge" text="12" />
                                                        <VBox alignment="CENTER" spacing="15.0">
                                                            <children>
                                                                <Label text="📰" style="-fx-font-size: 40px; -fx-text-fill: #2d6a4f; -fx-opacity: 0.7;" />
                                                                <Label styleClass="card-title-lg" text="Create article" />
                                                                <Label styleClass="card-subtitle" text="Publish a new blog article" textAlignment="CENTER" wrapText="true" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </VBox>

                                        <!-- Comments -->
                                        <VBox styleClass="stat-card">
                                            <children>
                                                <VBox alignment="CENTER" spacing="15.0">
                                                    <children>
                                                        <Label text="💬" style="-fx-font-size: 40px; -fx-text-fill: #2d6a4f; -fx-opacity: 0.7;" />
                                                        <Label styleClass="card-title-lg" text="Comments" />
                                                        <Label styleClass="card-subtitle" text="View and flag comments" textAlignment="CENTER" wrapText="true" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <!-- Create event -->
                                        <VBox styleClass="stat-card">
                                            <children>
                                                <StackPane alignment="TOP_RIGHT">
                                                    <children>
                                                        <Label styleClass="stat-badge" text="5" />
                                                        <VBox alignment="CENTER" spacing="15.0">
                                                            <children>
                                                                <Label text="📅" style="-fx-font-size: 40px; -fx-text-fill: #2d6a4f; -fx-opacity: 0.7;" />
                                                                <Label styleClass="card-title-lg" text="Create event" />
                                                                <Label styleClass="card-subtitle" text="Add a new event" textAlignment="CENTER" wrapText="true" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </VBox>

                                        <!-- My Achievements -->
                                        <VBox styleClass="stat-card">
                                            <children>
                                                <VBox alignment="CENTER" spacing="15.0">
                                                    <children>
                                                        <Label text="🏆" style="-fx-font-size: 40px; -fx-text-fill: #2d6a4f; -fx-opacity: 0.7;" />
                                                        <Label styleClass="card-title-lg" text="My Achievements" />
                                                        <Label styleClass="card-subtitle" text="Review your history of successfully resolved tickets." textAlignment="CENTER" wrapText="true" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </FlowPane>

                                <!-- USER CARDS GRID -->
                                <FlowPane fx:id="userCardsGrid" hgap="25.0" vgap="25.0" styleClass="dashboard-grid" visible="false" managed="false">
                                    <children>
                                        <VBox onMouseClicked="#goToMyTicketsGrid" styleClass="stat-card">
                                            <children>
                                                <StackPane alignment="TOP_RIGHT">
                                                    <children>
                                                        <Label styleClass="stat-badge" text="9" />
                                                        <VBox alignment="CENTER" spacing="15.0">
                                                            <children>
                                                                <Label text="🎫" style="-fx-font-size: 40px;" />
                                                                <Label styleClass="card-title-lg" text="My tickets" />
                                                                <Label styleClass="card-subtitle" text="View and manage your submitted environmental tickets" textAlignment="CENTER" wrapText="true" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </VBox>
                                        <VBox onMouseClicked="#goToCreateTicketGrid" styleClass="stat-card">
                                            <children>
                                                <VBox alignment="CENTER" spacing="15.0">
                                                    <children>
                                                        <Label text="➕" style="-fx-font-size: 40px;" />
                                                        <Label styleClass="card-title-lg" text="Create a ticket" />
                                                        <Label styleClass="card-subtitle" text="Report an environmental issue or suggestion quickly" textAlignment="CENTER" wrapText="true" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </FlowPane>
                            </children>
                        </StackPane>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</HBox>
