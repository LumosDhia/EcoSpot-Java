<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.home.HomeController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <top>
        <VBox>
            <!-- ===== TOP DARK BAR ===== -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="top-bar">
                <padding><Insets bottom="8.0" left="20.0" right="20.0" top="8.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHome" style="-fx-cursor: hand;" styleClass="top-bar-brand" text="🌿 EcoSpot" />
                    
                    <!-- Guest Links -->
                    <HBox fx:id="authLinks" alignment="CENTER_LEFT" spacing="20.0">
                        <children>
                            <Button onAction="#goToLogin" styleClass="top-bar-link" text="🔑 Login" />
                            <Button onAction="#goToRegister" styleClass="top-bar-link" text="👤 Register" />
                        </children>
                    </HBox>

                    <!-- Logged-in Links -->
                    <HBox fx:id="userLinks" alignment="CENTER_LEFT" managed="false" spacing="20.0" visible="false">
                        <children>
                            <Button fx:id="dashboardTopBtn" onAction="#goToDashboard" styleClass="top-bar-link" text="📊 Dashboard" />
                            <Button onAction="#handleLogout" styleClass="top-bar-link" text="🚪 Logout" />
                        </children>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS" />
                </children>
            </HBox>

            <!-- ===== WHITE SECONDARY NAV ===== -->
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="main-nav">
                <padding><Insets bottom="12.0" left="20.0" right="20.0" top="12.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHome" style="-fx-cursor: hand;" styleClass="brand-name" text="EcoSpot" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button styleClass="nav-link-btn" text="Home" />
                    <Button styleClass="nav-link-btn" text="Events" />
                    <Button onAction="#goToTickets" styleClass="nav-link-btn" text="🎟 Tickets" />
                    <Button styleClass="nav-link-btn" text="Achievements" />
                    <Button fx:id="blogBtn" onAction="#goToBlog" styleClass="nav-btn-blog" text="Blog" />
                </children>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f0f7f4; -fx-background: #f0f7f4;">
            <content>
                <VBox spacing="0.0">
                    <!-- ===== HERO SECTION ===== -->
                    <VBox alignment="CENTER" spacing="0.0" styleClass="hero-banner">
                        <children>
                            <VBox alignment="CENTER" maxWidth="Infinity" spacing="18.0" styleClass="hero-overlay" VBox.vgrow="ALWAYS">
                                <padding><Insets bottom="80.0" left="40.0" right="40.0" top="80.0" /></padding>
                                <children>
                                    <Label styleClass="hero-title" text="Welcome to EcoSpot" />
                                    <Label alignment="CENTER" maxWidth="600.0" styleClass="hero-subtitle" text="Your place for environmental news, events, and action." textAlignment="CENTER" wrapText="true" />
                                    <HBox alignment="CENTER" spacing="15.0">
                                        <padding><Insets top="10.0" /></padding>
                                        <children>
                                            <Button fx:id="heroBlogBtn" onAction="#goToBlog" styleClass="btn-hero-primary" text="Blog" />
                                            <Button styleClass="btn-hero-outline" text="Events" />
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <!-- ===== ABOUT SECTION ===== -->
                    <HBox alignment="CENTER" spacing="60.0" styleClass="about-section">
                        <padding><Insets bottom="50.0" left="60.0" right="60.0" top="50.0" /></padding>
                        <children>
                            <VBox HBox.hgrow="ALWAYS" maxWidth="480.0" spacing="12.0">
                                <children>
                                    <Label styleClass="about-title" text="About EcoSpot" />
                                    <Label styleClass="about-text" text="EcoSpot brings together articles, events, and community around environmental protection and nature." wrapText="true" />
                                    <Label styleClass="about-text" text="Read the latest on the blog, discover upcoming events, and connect with initiatives that make a real difference for our planet." wrapText="true" />
                                </children>
                            </VBox>
                            <Label style="-fx-font-size: 90px;" text="🌿" />
                        </children>
                    </HBox>

                    <!-- ===== EXPLORE CARDS SECTION ===== -->
                    <VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #e9f5ee;">
                        <padding><Insets bottom="60.0" left="60.0" right="60.0" top="50.0" /></padding>
                        <children>
                            <Label styleClass="section-title" text="Explore Our Platform" />
                            <HBox alignment="CENTER" spacing="20.0">
                                <children>
                                    <VBox alignment="CENTER" spacing="12.0" styleClass="explore-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label style="-fx-font-size: 36px;" text="📰" />
                                            <Label styleClass="card-title" text="Blog" />
                                            <Label styleClass="card-text" text="Read the latest ecological news and articles." textAlignment="CENTER" wrapText="true" />
                                        </children>
                                    </VBox>
                                    <VBox alignment="CENTER" spacing="12.0" styleClass="explore-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label style="-fx-font-size: 36px;" text="📅" />
                                            <Label styleClass="card-title" text="Events" />
                                            <Label styleClass="card-text" text="Join community events and workshops near you." textAlignment="CENTER" wrapText="true" />
                                        </children>
                                    </VBox>
                                    <VBox alignment="CENTER" onMouseClicked="#goToTicketsFromIcon" spacing="12.0" style="-fx-cursor: hand;" styleClass="explore-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label style="-fx-font-size: 36px;" text="🎟" />
                                            <Label styleClass="card-title" text="Tickets" />
                                            <Label styleClass="card-text" text="Get your passes for upcoming workshops." textAlignment="CENTER" wrapText="true" />
                                        </children>
                                    </VBox>
                                    <VBox alignment="CENTER" spacing="12.0" styleClass="explore-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label style="-fx-font-size: 36px;" text="🏆" />
                                            <Label styleClass="card-title" text="Achievements" />
                                            <Label styleClass="card-text" text="Track your eco-impact and community milestones." textAlignment="CENTER" wrapText="true" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
