<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.home.HomeController">
    <stylesheets>
        <URL value="@../style.css" />
    </stylesheets>

    <top>
        <VBox>
            <!-- ===== TOP DARK BAR ===== -->
            <HBox alignment="CENTER_LEFT" styleClass="top-bar" spacing="20.0">
                <padding><Insets left="20.0" right="20.0" top="8.0" bottom="8.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHome" style="-fx-cursor: hand;" styleClass="top-bar-brand" text="🌿 EcoSpot" />
                    <Button styleClass="top-bar-link" text="🔑 Login" />
                    <Button styleClass="top-bar-link" text="👤 Register" />
                    <Region HBox.hgrow="ALWAYS" />
                </children>
            </HBox>

            <!-- ===== WHITE SECONDARY NAV ===== -->
            <HBox alignment="CENTER_LEFT" styleClass="main-nav" spacing="10.0">
                <padding><Insets left="20.0" right="20.0" top="12.0" bottom="12.0" /></padding>
                <children>
                    <Label onMouseClicked="#goToHome" style="-fx-cursor: hand;" styleClass="brand-name" text="EcoSpot" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button styleClass="nav-link-btn" text="Home" />
                    <Button styleClass="nav-link-btn" text="Events" />
                    <Button styleClass="nav-link-btn-active" text="🎟 Tickets" />
                    <Button styleClass="nav-link-btn" text="Achievements" />
                    <Button fx:id="blogBtn" onAction="#goToBlog" styleClass="nav-btn-blog" text="Blog" />
                </children>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f0f7f4; -fx-background: #f0f7f4;">
            <content>
                <VBox spacing="0.0">
                    <!-- ===== HERO SECTION (full width background) ===== -->
                    <VBox alignment="CENTER" spacing="0.0" styleClass="hero-banner">
                        <children>
                            <VBox alignment="CENTER" spacing="18.0" styleClass="hero-overlay" maxWidth="Infinity" HBox.hgrow="ALWAYS">
                                <padding><Insets bottom="80.0" left="40.0" right="40.0" top="80.0" /></padding>
                                <children>
                                    <Label styleClass="hero-title" text="Welcome to EcoSpot" />
                                    <Label alignment="CENTER" maxWidth="600.0" styleClass="hero-subtitle" text="Your place for environmental news, events, and action." textAlignment="CENTER" wrapText="true" />
                                    <HBox alignment="CENTER" spacing="15.0">
                                        <padding><Insets top="10.0" /></padding>
                                        <children>
                                            <Button fx:id="heroBlogBtn" onAction="#goToBlog" styleClass="btn-hero-primary" text="Blog" />
                                            <Button styleClass="btn-hero-outline" text="Events" />
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <!-- ===== ABOUT SECTION ===== -->
                    <HBox alignment="CENTER" spacing="60.0" styleClass="about-section">
                        <padding><Insets top="50.0" bottom="50.0" left="60.0" right="60.0" /></padding>
                        <children>
                            <VBox spacing="12.0" HBox.hgrow="ALWAYS" maxWidth="480.0">
                                <children>
                                    <Label text="About EcoSpot" styleClass="about-title" />
                                    <Label text="EcoSpot brings together articles, events, and community around environmental protection and nature."
                                           styleClass="about-text" wrapText="true" />
                                    <Label text="Read the latest on the blog, discover upcoming events, and connect with initiatives that make a real difference for our planet."
                                           styleClass="about-text" wrapText="true" />
                                </children>
                            </VBox>
                            <Label text="🌿" style="-fx-font-size: 90px;" />
                        </children>
                    </HBox>

                    <!-- ===== EXPLORE CARDS SECTION ===== -->
                    <VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #e9f5ee;">
                        <padding><Insets top="50.0" bottom="60.0" left="60.0" right="60.0" /></padding>
                        <children>
                            <Label text="Explore Our Platform" styleClass="section-title" />
                            <HBox alignment="CENTER" spacing="20.0">
                                <children>
                                    <VBox alignment="CENTER" spacing="12.0" styleClass="explore-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label text="📰" style="-fx-font-size: 36px;" />
                                            <Label text="Blog" styleClass="card-title" />
                                            <Label text="Read the latest ecological news and articles." styleClass="card-text" wrapText="true" textAlignment="CENTER" />
                                        </children>
                                    </VBox>
                                    <VBox alignment="CENTER" spacing="12.0" styleClass="explore-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label text="📅" style="-fx-font-size: 36px;" />
                                            <Label text="Events" styleClass="card-title" />
                                            <Label text="Join community events and workshops near you." styleClass="card-text" wrapText="true" textAlignment="CENTER" />
                                        </children>
                                    </VBox>
                                    <VBox alignment="CENTER" spacing="12.0" styleClass="explore-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label text="🎟" style="-fx-font-size: 36px;" />
                                            <Label text="Tickets" styleClass="card-title" />
                                            <Label text="Get your passes for upcoming workshops." styleClass="card-text" wrapText="true" textAlignment="CENTER" />
                                        </children>
                                    </VBox>
                                    <VBox alignment="CENTER" spacing="12.0" styleClass="explore-card" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label text="🏆" style="-fx-font-size: 36px;" />
                                            <Label text="Achievements" styleClass="card-title" />
                                            <Label text="Track your eco-impact and community milestones." styleClass="card-text" wrapText="true" textAlignment="CENTER" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
